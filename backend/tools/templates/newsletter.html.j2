<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ headline }}</title>
  <!--[if mso]><style>body,table,td{font-family:Arial,Helvetica,sans-serif !important;}</style><![endif]-->
</head>
<body style="margin:0; padding:0; background-color:#F2F4F7; -webkit-font-smoothing:antialiased;">

<!-- Outer wrapper -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F2F4F7;">
  <tr>
    <td align="center" style="padding:24px 16px;">

      <!-- Inner content table -->
      <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="background-color:#FFFFFF; border-radius:8px; overflow:hidden; max-width:600px;">

        <!-- ============ HEADER ============ -->
        <tr>
          <td bgcolor="#2367D3" style="background-color:#2367D3; padding:28px 32px; text-align:center;">
            {% if logo_url %}
            <img src="{{ logo_url }}" alt="AI Newsletter" width="160" style="display:block; margin:0 auto 16px auto; max-width:160px; height:auto;">
            {% endif %}
            <h1 style="margin:0; padding:0; color:#FFFFFF; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:26px; font-weight:700; line-height:1.3;">{{ headline }}</h1>
            {% if subtitle %}
            <p style="margin:8px 0 0 0; color:#D4E6FF; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:15px; font-weight:400; line-height:1.4;">{{ subtitle }}</p>
            {% endif %}
          </td>
        </tr>

        <!-- ============ SUMMARY ============ -->
        <tr>
          <td style="padding:28px 32px 20px 32px;">
            <p style="margin:0; color:#333333; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:16px; line-height:1.7;">{{ summary }}</p>
          </td>
        </tr>

        <!-- Divider -->
        <tr>
          <td style="padding:0 32px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr><td style="border-top:2px solid #F0F2F5; font-size:1px; line-height:1px;">&nbsp;</td></tr>
            </table>
          </td>
        </tr>

        <!-- ============ CONTENT SECTIONS ============ -->
        {% for section in sections %}
        <tr>
          <td style="padding:24px 32px 8px 32px;">
            <h2 style="margin:0 0 12px 0; color:#2367D3; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:20px; font-weight:700; line-height:1.3;">{{ section.heading }}</h2>
            <p style="margin:0; color:#444444; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:15px; line-height:1.7;">{{ section.body }}</p>
          </td>
        </tr>

        {% if section.key_stat %}
        <!-- Pull-quote callout -->
        <tr>
          <td style="padding:8px 32px 8px 32px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#F0F0FF; border-left:4px solid #4B3FE0; border-radius:0 4px 4px 0;">
              <tr>
                <td style="padding:14px 20px;">
                  <p style="margin:0; color:#2367D3; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:17px; font-weight:700; line-height:1.5;">{{ section.key_stat }}</p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        {% endif %}

        {% if not loop.last %}
        <!-- Section divider -->
        <tr>
          <td style="padding:12px 32px 0 32px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr><td style="border-top:1px solid #F0F2F5; font-size:1px; line-height:1px;">&nbsp;</td></tr>
            </table>
          </td>
        </tr>
        {% endif %}
        {% endfor %}

        <!-- ============ INFOGRAPHIC ============ -->
        {% if infographic_url %}
        <tr>
          <td style="padding:24px 32px 8px 32px;">
            <h3 style="margin:0 0 12px 0; color:#8331A6; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:16px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px;">Visual Breakdown</h3>
          </td>
        </tr>
        <tr>
          <td style="padding:0 32px 16px 32px;" align="center">
            <img src="{{ infographic_url }}" alt="Infographic" width="536" style="display:block; max-width:100%; height:auto; border-radius:6px;">
          </td>
        </tr>
        {% endif %}

        <!-- ============ DATA CHART ============ -->
        {% if chart_url %}
        <tr>
          <td style="padding:16px 32px 8px 32px;">
            <h3 style="margin:0 0 12px 0; color:#8331A6; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:16px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px;">By The Numbers</h3>
          </td>
        </tr>
        <tr>
          <td style="padding:0 32px 16px 32px;" align="center">
            <img src="{{ chart_url }}" alt="{{ chart_title }}" width="536" style="display:block; max-width:100%; height:auto; border-radius:6px;">
          </td>
        </tr>
        {% endif %}

        <!-- ============ CTA ============ -->
        {% if cta %}
        <tr>
          <td style="padding:24px 32px;" align="center">
            <table role="presentation" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td bgcolor="#2F94FB" style="background-color:#2F94FB; border-radius:6px;">
                  <a href="{{ cta.url }}" target="_blank" style="display:inline-block; padding:14px 36px; color:#FFFFFF; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:15px; font-weight:700; text-decoration:none;">{{ cta.text }}</a>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        {% endif %}

        <!-- ============ SOURCES ============ -->
        {% if sources %}
        <tr>
          <td style="padding:16px 32px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr><td style="border-top:2px solid #F0F2F5; font-size:1px; line-height:1px;">&nbsp;</td></tr>
            </table>
          </td>
        </tr>
        <tr>
          <td style="padding:0 32px 24px 32px;">
            <p style="margin:0 0 8px 0; color:#999999; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px;">Sources</p>
            {% for source in sources %}
            <p style="margin:0 0 4px 0; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:13px; line-height:1.5;">
              <a href="{{ source.url }}" target="_blank" style="color:#2F94FB; text-decoration:none;">{{ source.title }}</a>
            </p>
            {% endfor %}
          </td>
        </tr>
        {% endif %}

        <!-- ============ FOOTER ============ -->
        <tr>
          <td bgcolor="#F8F9FB" style="background-color:#F8F9FB; padding:20px 32px; text-align:center;">
            <p style="margin:0; color:#AAAAAA; font-family:'Poppins',Arial,Helvetica,sans-serif; font-size:12px; line-height:1.5;">
              AI Newsletter &bull; Generated on {{ date }}<br>
              You received this because you subscribed.
            </p>
          </td>
        </tr>

      </table>
      <!-- /Inner content table -->

    </td>
  </tr>
</table>
<!-- /Outer wrapper -->

</body>
</html>
